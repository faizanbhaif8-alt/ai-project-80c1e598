        <a href="{{ url_for('index', filter='active') }}" class="{% if filter_type == 'active' %}active{% endif %}">Active</a>
        <a href="{{ url_for('index', filter='completed') }}" class="{% if filter_type == 'completed' %}active{% endif %}">Completed</a>
