**3. templates/index.html (main template):**
```html
{% extends "base.html" %}

{% block content %}
    <div class="todo-form">
        <form action="/" method="POST">
            <input type="text" name="content" id="content" placeholder="Add new task..." required>
            <button type="submit">Add Task</button>
        </form>
    </div>

    {% if tasks|length < 1 %}
        <p class="no-tasks">No tasks yet. Add one above!</p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Added</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for task in tasks %}
                    <tr>
                        <td {% if task.completed %}class="completed"{% endif %}>{{ task.content }}</td>
                        <td>{{ task.date_created.strftime('%Y-%m-%d %H:%M') }}</td>
                        <td>
                            {% if task.completed %}
                                Completed
                            {% else %}
                                Active
                            {% endif %}
                        </td>
                        <td class="actions">
                            {% if not task.completed %}
                                <a href="{{ url_for('complete', id=task.id) }}" class="complete-btn">Complete</a>
                            {% else %}
                                <a href="{{ url_for('uncomplete', id=task.id) }}" class="uncomplete-btn">Uncomplete</a>
                            {% endif %}
                            <a href="{{ url_for('delete', id=task.id) }}" class="delete-btn">Delete</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
```

