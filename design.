**3. templates/index.html (main page):**
```html
{% extends "base.html" %}

{% block content %}
<div class="todo-container">
    <form action="/" method="POST" class="mb-4">
        <div class="input-group">
            <input type="text" name="content" id="content" class="form-control" placeholder="Add new task..." required>
            <button type="submit" class="btn btn-primary">Add Task</button>
        </div>
    </form>

    {% if tasks %}
        <ul class="list-group">
            {% for task in tasks %}
                <li class="list-group-item d-flex justify-content-between align-items-center {% if task.completed %}completed{% endif %}">
                    <div>
                        <input type="checkbox" class="form-check-input me-2" 
                               onclick="window.location.href='{{ url_for('complete', id=task.id) }}'"
                               {% if task.completed %}checked{% endif %}>
                        <span class="task-content">{{ task.content }}</span>
                    </div>
                    <div>
                        <small class="text-muted me-2">{{ task.date_created.strftime('%Y-%m-%d') }}</small>
                        <a href="{{ url_for('delete', id=task.id) }}" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p class="text-center">No tasks yet. Add one above!</p>
    {% endif %}
</div>
{% endblock %}
```

